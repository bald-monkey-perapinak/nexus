# ═══════════════════════════════════════════════════════
# NEXUS · Environment Variables
# Скопируй в .env и заполни свои значения
# ═══════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/nexus
REDIS_URL=redis://redis:6379

# Telegram
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_IDS=123456789
WEBAPP_URL=https://your-domain.ngrok-free.app




# ── LLM Провайдеры ──────────────────────────────────────
# Система автоматически переключается между провайдерами
# при rate limit. Чем больше ключей — тем выше надёжность.

# [1] Groq — ОСНОВНОЙ (обязательно)
# Получить бесплатно: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# [2] Google Gemini Flash — FALLBACK #1 (рекомендуется)
# 1500 req/day бесплатно
# Получить: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [3] OpenRouter — FALLBACK #2 (рекомендуется)
# Бесплатные модели без дневного лимита
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=

#вставить в окружение
# ── Security ─────────────────────────────────────────────
JWT_SECRET=nexus-change-me-in-production-random-string-32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# ── App ──────────────────────────────────────────────────
DEBUG=false

# Лимит генераций идей на пользователя в день (защита от злоупотреблений)
USER_DAILY_GENERATION_LIMIT=5
